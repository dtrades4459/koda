# ── Supabase (browser-safe) ────────────────────────────────────────────────────
VITE_SUPABASE_URL=https://your-project.supabase.co
VITE_SUPABASE_ANON_KEY=your-anon-key-here

# ── Supabase (server-only — never expose to browser) ──────────────────────────
SUPABASE_URL=https://your-project.supabase.co
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key-here

# ── Broker sync ────────────────────────────────────────────────────────────────
# AES-256-GCM key for encrypting broker tokens at rest.
# Generate: node -e "console.log(require('crypto').randomBytes(32).toString('hex'))"
TRADR_ENCRYPTION_KEY=64-hex-chars-here

# Random secret sent by Vercel Cron as x-cron-secret header.
# Must match the value in vercel.json cron → headers.
CRON_SECRET=your-random-secret-here

# Tradovate API credentials (get from developer.tradovate.com)
TRADOVATE_APP_ID=your-app-id
TRADOVATE_APP_VERSION=1.0
TRADOVATE_CID=your-cid
TRADOVATE_SEC=your-sec-secret

# ── Feedback bot ───────────────────────────────────────────────────────────────
TELEGRAM_BOT_TOKEN=your-telegram-bot-token
TELEGRAM_CHAT_ID=your-chat-id

# ── Stripe billing ─────────────────────────────────────────────────────────────
STRIPE_SECRET_KEY=sk_live_...
STRIPE_WEBHOOK_SECRET=whsec_...
STRIPE_PRICE_ID=price_...

# ── Analytics ─────────────────────────────────────────────────────────────────
# PostHog — leave blank to disable.
VITE_POSTHOG_KEY=phc_...
VITE_POSTHOG_HOST=https://eu.i.posthog.com

# ── Error monitoring ──────────────────────────────────────────────────────────
# Optional — leave blank to disable Sentry.
# To enable: npm install @sentry/react
VITE_SENTRY_DSN=

# ── Beta access wall ──────────────────────────────────────────────────────────
# If set, shows a password gate before auth. Leave blank to disable.
VITE_BETA_PASSWORD=
